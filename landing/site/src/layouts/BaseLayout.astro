---
import '../styles/global.css'

interface Props {
  title: string
  description: string
  ogImage?: string
  structuredData?: object | object[]
  lang?: string
  ogLocale?: string
  alternates?: Array<{
    href: string
    hrefLang: string
  }>
}

const {
  title,
  description,
  ogImage = '/og-image.svg',
  structuredData,
  lang = 'es',
  ogLocale = 'es_AR',
  alternates = [],
} = Astro.props
const site = Astro.site ? new URL(Astro.site) : new URL('https://prodefi.online')
const canonical = new URL(Astro.url.pathname, site)
const gaMeasurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-CVPJ7VDK9E'
const googleFontsStylesheet =
  'https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@400;500;600;700;800&family=Fraunces:opsz,wght@9..144,400;9..144,500&family=JetBrains+Mono:wght@400;500;700&display=swap'
const schemaItems = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'ProDefi',
    url: site.origin,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'ProDefi',
    url: site.origin,
    inLanguage: lang,
  },
  ...(Array.isArray(structuredData)
    ? structuredData
    : structuredData
      ? [structuredData]
      : []),
]
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="ProDefi" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, site)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, site)} />

    <meta name="theme-color" content="#07090f" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {
      gaMeasurementId && (
        <>
          <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`}></script>
          <script is:inline define:vars={{ gaMeasurementId }}>
            window.dataLayer = window.dataLayer || []
            function gtag() {
              dataLayer.push(arguments)
            }
            gtag('js', new Date())
            gtag('config', gaMeasurementId)
          </script>
        </>
      )
    }

    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hrefLang} href={new URL(alternate.href, site)} />
    ))}

    {schemaItems.map((item) => (
      <script type="application/ld+json" set:html={JSON.stringify(item)} />
    ))}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href={googleFontsStylesheet} as="style" />
    <link rel="stylesheet" href={googleFontsStylesheet} media="print" onload="this.media='all'" />
    <noscript>
      <link rel="stylesheet" href={googleFontsStylesheet} />
    </noscript>
  </head>
  <body>
    <slot />
  </body>
</html>
