---
import { Image } from 'astro:assets'
import worldCupPoster from '../images/poster-mundial-fifa-2026.webp'
import SiteFooter from './SiteFooter.astro'
import SiteHeader from './SiteHeader.astro'
import type { LandingContent } from '../data/landing-content'

interface Props {
  content: LandingContent
  waitlistAction: string
  rulesHref: string
}

const { content, waitlistAction, rulesHref } = Astro.props
const site = Astro.site ? new URL(Astro.site) : new URL('https://prodefi.online')
const shareUrl = new URL(Astro.url.pathname, site).toString()
const languageLinks = [
  { href: '/', label: 'ES', isCurrent: content.locale === 'es' },
  { href: '/en/', label: 'EN', isCurrent: content.locale === 'en' },
]
---

<a class="skip-link" href="#contenido">{content.locale === 'es' ? 'Saltar al contenido' : 'Skip to content'}</a>

<SiteHeader
  locale={content.locale}
  brandHref="#top"
  brandAriaLabel={content.header.brandAriaLabel}
  nav={content.header.nav}
  ctaHref="https://app.prodefi.online"
  ctaLabel={content.header.ctaLabel}
  languageLinks={languageLinks}
/>

<main id="contenido">
  <section class="hero" id="top">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="shell hero-grid">
      <div class="hero-copy">
        <div class="kicker-row">
          <span class="kicker-line"></span>
          <p class="eyebrow eyebrow--celeste">{content.hero.eyebrow}</p>
        </div>

        <h1 class:list={['display', 'hero-title', content.locale === 'en' && 'hero-title--en']}>
          {content.hero.titlePrimary}<br />
          <span class="editorial">{content.hero.titleEditorial}</span>
        </h1>

        <p class="hero-lead" set:html={content.hero.lead}></p>

        <div class="cta-row">
          <a class="button button--accent" href="https://app.prodefi.online" target="_blank" rel="noopener noreferrer">{content.header.ctaLabel}</a>
        </div>

        <p class="trust-row">
          <span class="trust-dot"></span>
          <span>{content.hero.trust}</span>
        </p>
      </div>

      <div class="hero-visual">
        <div class="hero-card">
          <Image
            class="hero-card__poster"
            src={worldCupPoster}
            alt={content.hero.posterAlt}
            width={960}
            height={1200}
            layout="constrained"
            fit="cover"
            widths={[360, 530, 720, 960]}
            sizes="(max-width: 767px) 88vw, (max-width: 1199px) 42vw, 530px"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <div class="hero-card__grain"></div>
        </div>
      </div>
    </div>

    <div class="afa-stripe" aria-hidden="true"></div>

    <div class="hero-steps-wrap">
      <div class="shell hero-steps">
        {content.steps.map((step, index) => (
          <article class:list={["step-card", index > 0 && 'step-card--bordered']}>
            <p class="step-number">{content.locale === 'es' ? 'Paso' : 'Step'} {step.number}</p>
            <h2 class="display step-title">{step.title}</h2>
            <p class="step-description">{step.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="countdown-section" id="countdown" data-target-date={content.page.targetDate}>
    <div class="countdown-watermark" aria-hidden="true">2026</div>
    <div class="shell section-inner">
      <div class="section-topline">
        <div class="kicker-row">
          <span class="kicker-line"></span>
          <p class="eyebrow eyebrow--celeste">{content.countdown.eyebrow}</p>
        </div>
        <p class="microcopy countdown-microcopy">
          {content.page.targetDateLabel} · {content.page.targetTimeLabel}
        </p>
      </div>

      <h2 class="display section-title section-title--countdown">
        {content.countdown.titlePrimary} <span class="editorial">{content.countdown.titleEditorial}</span>
      </h2>
      <p class="section-lead section-lead--countdown">{content.countdown.lead}</p>

      <div class="countdown-grid" aria-label={content.countdown.ariaLabel}>
        <div class="countdown-cell">
          <span class="display countdown-value" data-countdown="days">00</span>
          <span class="eyebrow">{content.countdown.valueLabels.days}</span>
        </div>
        <div class="countdown-cell">
          <span class="display countdown-value" data-countdown="hours">00</span>
          <span class="eyebrow">{content.countdown.valueLabels.hours}</span>
        </div>
        <div class="countdown-cell">
          <span class="display countdown-value" data-countdown="minutes">00</span>
          <span class="eyebrow">{content.countdown.valueLabels.minutes}</span>
        </div>
        <div class="countdown-cell">
          <span class="display countdown-value" data-countdown="seconds">00</span>
          <span class="eyebrow">{content.countdown.valueLabels.seconds}</span>
        </div>
      </div>

      <div class="meta-strip">
        {content.countdown.metaStrip.map((item) => <span>{item}</span>)}
      </div>
    </div>
  </section>

  <section class="prizes-section" id="premios">
    <div class="afa-stripe afa-stripe--thin" aria-hidden="true"></div>
    <div class="shell section-inner section-inner--light">
      <div class="kicker-row kicker-row--ink">
        <span class="kicker-line kicker-line--ink"></span>
        <p class="eyebrow eyebrow--ink">{content.prizes.eyebrow}</p>
      </div>

      <div class="prizes-headline">
        <h2 class="display section-title section-title--ink">
          {content.prizes.titlePrimary}<br /><span class="editorial">{content.prizes.titleEditorial}</span>
        </h2>
        <p class="section-lead section-lead--ink">{content.prizes.lead}</p>
      </div>

      <div class="prize-grid">
        {content.prizes.prizeCards.map((card, index) => (
          <article
            class:list={[
              'prize-card',
              index === 0 && 'prize-card--dark',
              index === 1 && 'prize-card--celeste',
              index === 2 && 'prize-card--light',
            ]}
          >
            <p class:list={['eyebrow', index === 0 ? 'eyebrow--lima' : 'eyebrow--ink']}>
              {card.eyebrow}
            </p>
            <h3 class="display prize-heading">{card.title}</h3>
            <p class:list={['prize-body', index === 2 && 'prize-body--muted']}>{card.description}</p>
            <p class="prize-note">{card.note}</p>
            {card.href && card.cta && <a class="button button--outline" href={rulesHref} target="_blank" rel="noopener noreferrer">{card.cta}</a>}
          </article>
        ))}
      </div>

      <div class="light-meta-strip">
        {content.prizes.metaStrip.map((item) => <span>{item}</span>)}
      </div>
    </div>
    <div class="afa-stripe afa-stripe--thin" aria-hidden="true"></div>
  </section>

  {false && (
  <section class="waitlist-section" id="waitlist" data-waitlist-action={waitlistAction}>
    <div class="waitlist-lines" aria-hidden="true"></div>
    <div class="shell waitlist-inner">
      <div class="waitlist-kicker">
        <span class="kicker-line kicker-line--accent"></span>
        <p class="eyebrow eyebrow--lima">{content.waitlist.eyebrow}</p>
        <span class="kicker-line kicker-line--accent"></span>
      </div>

      <h2 class="display section-title section-title--center">
        {content.waitlist.titlePrimary}<br /><span class="editorial">{content.waitlist.titleEditorial}</span>
      </h2>

      <p class="section-lead section-lead--center">{content.waitlist.lead}</p>

      <form class="waitlist-form" method="post" action={waitlistAction} data-waitlist-form novalidate>
        <div class="honeypot-field" aria-hidden="true">
          <label for="waitlist-company">Company</label>
          <input id="waitlist-company" name="company" type="text" tabindex="-1" autocomplete="off" />
        </div>
        <input type="hidden" name="startedAt" value="" data-waitlist-started-at />
        <label class="sr-only" for="waitlist-email">{content.waitlist.emailLabel}</label>
        <input
          id="waitlist-email"
          name="email"
          type="email"
          placeholder={content.waitlist.emailPlaceholder}
          autocomplete="email"
          required
        />
        <button class="button button--accent" type="submit">{content.waitlist.buttonLabel}</button>
      </form>

      <p class="waitlist-feedback" data-waitlist-feedback aria-live="polite">
        {content.page.launchMessage}
      </p>
    </div>
  </section>
  <div class="afa-stripe afa-stripe--thin" aria-hidden="true"></div>
  )}

  <section class="faq-section" id="faq">
    <div class="shell section-inner">
      <div class="kicker-row">
        <span class="kicker-line"></span>
        <p class="eyebrow eyebrow--celeste">{content.faq.eyebrow}</p>
      </div>

      <h2 class="display section-title">
        {content.faq.titlePrimary} <span class="editorial">{content.faq.titleEditorial}</span>? {content.locale === 'es' ? 'Las sacamos' : 'We have you covered'}
      </h2>

      <div class="faq-list">
        {content.faq.items.map((item, index) => (
          <details class="faq-item" open={index === 0}>
            <summary>
              <span class="faq-title-wrap">
                <span class="mono faq-index">{String(index + 1).padStart(2, '0')}</span>
                <span class="display faq-question">{item.question}</span>
              </span>
              <span class="faq-plus" aria-hidden="true">+</span>
            </summary>
            <div class="faq-answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</main>

<SiteFooter locale={content.locale} footer={content.footer} shareUrl={shareUrl} shareTitle={content.page.title} />

<script is:inline>
  const countdownRoot = document.querySelector('[data-target-date]')
  if (countdownRoot) {
    const target = new Date(countdownRoot.dataset.targetDate || '').getTime()
    const nodes = {
      days: countdownRoot.querySelector('[data-countdown="days"]'),
      hours: countdownRoot.querySelector('[data-countdown="hours"]'),
      minutes: countdownRoot.querySelector('[data-countdown="minutes"]'),
      seconds: countdownRoot.querySelector('[data-countdown="seconds"]'),
    }

    const paintCountdown = () => {
      const diff = Math.max(0, target - Date.now())
      const days = Math.floor(diff / 86400000)
      const hours = Math.floor((diff % 86400000) / 3600000)
      const minutes = Math.floor((diff % 3600000) / 60000)
      const seconds = Math.floor((diff % 60000) / 1000)

      const values = { days, hours, minutes, seconds }
      for (const [key, value] of Object.entries(values)) {
        if (nodes[key]) nodes[key].textContent = String(value).padStart(2, '0')
      }
    }

    paintCountdown()
    window.setInterval(paintCountdown, 1000)
  }
</script>

{false && (
<script is:inline define:vars={{ waitlistMessages: content.waitlist.messages }}>
  const waitlistSection = document.querySelector('[data-waitlist-action]')
  const waitlistForm = document.querySelector('[data-waitlist-form]')
  const waitlistFeedback = document.querySelector('[data-waitlist-feedback]')
  if (waitlistSection && waitlistForm && waitlistFeedback) {
    const endpoint = waitlistSection.dataset.waitlistAction || ''
    const emailInput = waitlistForm.querySelector('input[type="email"]')
    const honeypotInput = waitlistForm.querySelector('input[name="company"]')
    const startedAtInput = waitlistForm.querySelector('[data-waitlist-started-at]')

    if (startedAtInput instanceof HTMLInputElement) {
      startedAtInput.value = String(Date.now())
    }

    waitlistForm.addEventListener('submit', async (event) => {
      if (!(emailInput instanceof HTMLInputElement)) return

      const email = emailInput.value.trim()
      const company = honeypotInput instanceof HTMLInputElement ? honeypotInput.value.trim() : ''
      const startedAt = startedAtInput instanceof HTMLInputElement ? startedAtInput.value : ''
      const isValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)
      if (!isValid) {
        event.preventDefault()
        waitlistFeedback.textContent = waitlistMessages.invalidEmail
        waitlistFeedback.dataset.state = 'error'
        return
      }

      if (!endpoint) {
        event.preventDefault()
        waitlistFeedback.textContent = waitlistMessages.noEndpoint
        waitlistFeedback.dataset.state = 'idle'
        return
      }

      event.preventDefault()
      waitlistFeedback.textContent = waitlistMessages.sending
      waitlistFeedback.dataset.state = 'idle'

      try {
        const response = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, company, startedAt }),
        })

        const payload = await response.json().catch(() => null)

        if (!response.ok) {
          if (response.status === 429 || payload?.error === 'rate-limit-exceeded') {
            waitlistFeedback.textContent = waitlistMessages.rateLimited
            waitlistFeedback.dataset.state = 'error'
            return
          }

          throw new Error('bad response')
        }

        waitlistForm.reset()
        if (startedAtInput instanceof HTMLInputElement) {
          startedAtInput.value = String(Date.now())
        }
        waitlistFeedback.textContent = waitlistMessages.success
        waitlistFeedback.dataset.state = 'success'
      } catch {
        waitlistFeedback.textContent = waitlistMessages.error
        waitlistFeedback.dataset.state = 'error'
      }
    })
  }
</script>
)}
