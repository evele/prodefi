---
interface FooterLink {
  href: string
  label: string
}

interface FooterContent {
  sections: {
    navigation: {
      label: string
      links: FooterLink[]
    }
    status: {
      label: string
      lines: string[]
    }
  }
  meta?: string[]
}

interface Props {
  locale: 'es' | 'en'
  footer: FooterContent
  shareUrl: string
  shareTitle: string
}

const { locale, footer, shareUrl, shareTitle } = Astro.props
const year = new Date().getFullYear()
const shareLabel = locale === 'es' ? 'Compartir' : 'Share'
const xLabel = locale === 'es' ? 'Compartir en X' : 'Share on X'
const telegramLabel = locale === 'es' ? 'Compartir en Telegram' : 'Share on Telegram'
const whatsappLabel = locale === 'es' ? 'Compartir en WhatsApp' : 'Share on WhatsApp'
const encodedUrl = encodeURIComponent(shareUrl)
const encodedTitle = encodeURIComponent(shareTitle)
const encodedMessage = encodeURIComponent(`${shareTitle} ${shareUrl}`)
---

<footer class="site-footer">
  <div class="afa-stripe afa-stripe--thin" aria-hidden="true"></div>
  <div class="shell footer-inner">
    <div class="footer-brand" aria-label="ProDefi">
      <p class="display footer-wordmark">PRODEFI</p>
      <span class="footer-brand-ball" aria-hidden="true">⚽</span>
    </div>

    <div class="footer-grid">
      <div>
        <p class="eyebrow">{footer.sections.navigation.label}</p>
        <div class="footer-links">
          {footer.sections.navigation.links.map((link) => <a href={link.href}>{link.label}</a>)}
        </div>
      </div>

      <div>
        <p class="eyebrow">{shareLabel}</p>
        <div class="share-links">
          <a
            class="share-link"
            href={`https://x.com/intent/post?text=${encodedTitle}&url=${encodedUrl}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={xLabel}
          >
            <span class="sr-only">X</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M18.244 2H21.5l-7.11 8.128L22.75 22h-6.545l-5.125-6.702L5.214 22H1.956l7.606-8.694L1.5 2h6.712l4.632 6.112L18.244 2Zm-1.141 18.056h1.804L7.228 3.846H5.292l11.81 16.21Z"></path>
            </svg>
          </a>

          <a
            class="share-link"
            href={`https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={telegramLabel}
          >
            <span class="sr-only">Telegram</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M21.408 4.593a2.23 2.23 0 0 0-2.246-.322L3.46 10.695c-1.37.55-1.286 2.52.13 2.95l3.93 1.2 1.52 4.738c.437 1.362 2.19 1.625 2.998.45l2.19-3.19 4.3 3.237c1.09.82 2.65.214 2.906-1.13l2.41-12.65a2.24 2.24 0 0 0-.836-2.207Zm-3.16 3.034-8.17 7.488a.75.75 0 0 0-.22.403l-.456 2.354-.96-2.992 9.807-8.98a.75.75 0 0 0-1.001-1.117l-10.9 8.473-2.084-.637 14.917-6.006-1.933 10.15-4.223-3.18a.75.75 0 0 0-1.05.167l-1.573 2.293.286-1.476 8.595-7.878a.75.75 0 1 0-1.014-1.102Z"></path>
            </svg>
          </a>

          <a
            class="share-link"
            href={`https://wa.me/?text=${encodedMessage}`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={whatsappLabel}
          >
            <span class="sr-only">WhatsApp</span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2a10 10 0 0 0-8.66 15l-1.22 4.45a.75.75 0 0 0 .92.92L7.5 21.15A10 10 0 1 0 12 2Zm0 18.5a8.46 8.46 0 0 1-4.14-1.08.75.75 0 0 0-.56-.07l-2.74.75.75-2.74a.75.75 0 0 0-.07-.56A8.5 8.5 0 1 1 12 20.5Zm4.85-6.35c-.26-.13-1.56-.77-1.8-.86-.24-.09-.42-.13-.6.13-.17.26-.69.85-.84 1.02-.16.17-.31.2-.57.07-.26-.13-1.1-.41-2.1-1.3-.78-.7-1.3-1.56-1.45-1.82-.16-.26-.02-.4.11-.53.12-.12.26-.31.39-.46.13-.15.17-.26.26-.43.09-.17.04-.33-.02-.46-.06-.13-.6-1.43-.82-1.95-.22-.53-.44-.45-.6-.46h-.51c-.17 0-.46.07-.7.33-.24.26-.92.9-.92 2.19 0 1.29.94 2.53 1.07 2.71.13.17 1.85 2.83 4.49 3.96.63.27 1.12.43 1.5.54.63.2 1.2.17 1.65.1.5-.07 1.56-.64 1.78-1.26.22-.62.22-1.16.15-1.27-.06-.11-.24-.17-.5-.3Z"></path>
            </svg>
          </a>
        </div>
      </div>

      <div>
        <p class="eyebrow">{footer.sections.status.label}</p>
        <div class="footer-links">
          {footer.sections.status.lines.map((line) => <p class="footer-note">{line}</p>)}
        </div>
      </div>
    </div>

    {footer.meta && (
      <div class="footer-meta">
        <span>© {year} {footer.meta[0]}</span>
        <span>{footer.meta[1]}</span>
      </div>
    )}
  </div>
</footer>
