---
import BaseLayout from '../../layouts/BaseLayout.astro'
import RulesPage from '../../components/RulesPage.astro'
import { rulesContent } from '../../data/rules-content'

const content = rulesContent.en

const breadcrumbStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://prodefi.online/en/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: content.hero.eyebrow,
      item: 'https://prodefi.online/en/rules/',
    },
  ],
}

const alternates = [
  { href: '/reglas/', hrefLang: 'es' },
  { href: '/en/rules/', hrefLang: 'en' },
  { href: '/reglas/', hrefLang: 'x-default' },
]
---

<BaseLayout
  title={content.page.title}
  description={content.page.description}
  structuredData={breadcrumbStructuredData}
  lang="en"
  ogLocale="en_US"
  alternates={alternates}
>
  <RulesPage content={content} />
</BaseLayout>
