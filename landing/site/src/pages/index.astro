---
import BaseLayout from '../layouts/BaseLayout.astro'
import worldCupPoster from '../images/poster-mundial-fifa-2026.webp'

const waitlistAction = import.meta.env.PUBLIC_WAITLIST_ACTION || '/api/waitlist'

const page = {
  title: 'Prode Mundial 2026 | Predicciones y premios | ProDefi',
  description:
    'Jugá al Prode Mundial 2026 con predicciones, ranking verificable, reglas públicas y premios reales. Sumate a la lista de espera de ProDefi.',
  waitlistAction,
  launchMessage: 'Dejá tu mail y te avisamos apenas abramos los cartones.',
  targetDate: '2026-06-11T16:00:00-03:00',
  targetDateLabel: '11 de junio de 2026',
  targetTimeLabel: '16:00 Buenos Aires',
}

const prizeCards = [
  {
    eyebrow: 'Pozo',
    title: 'Pozo en aumento',
    description: 'El 95% de lo recaudado por cartones integra el pozo premiable de esa edición.',
    note: 'El 5% restante cubre infraestructura, mantenimiento y subsidio de gas.',
  },
  {
    eyebrow: 'Puestos',
    title: '32 ganadores',
    description: 'Del 1° al 32°: campeón, segundo, tercero, cuarto, cuartos, octavos y dieciseisavos  .',
  },
  {
    eyebrow: 'Reglas',
    title: 'Reglas públicas',
    description: 'La fórmula de puntaje, los premios y las reglas de empates quedan publicadas para que sepas a qué jugás.',
    note: '',
    href: '/reglas',
    cta: 'Ver reglas y criterios',
  },
]

const steps = [
  {
    number: '01',
    title: 'Conseguí tu cartón',
    description: 'Tu entrada al ranking del Mundial. Un cartón, una chance real de pelear arriba.',
  },
  {
    number: '02',
    title: 'Hacé tus predicciones',
    description: 'Cargá resultados exactos y tu top 4 del torneo. La lectura de partido corre por tu cuenta.',
  },
  {
    number: '03',
    title: 'Competí por premios',
    description: 'Cada acierto suma. Si hay empate en puntos, comparten posición y se divide el bloque de premios.',
  },
]

const faqItems = [
  {
    question: '¿Qué es ProDefi?',
    answer:
      'ProDefi es un Prode Mundial 2026 con reglas onchain. Conseguís tu cartón, cargás predicciones de resultados y competís contra otros hinchas en un único ranking global.',
  },
  {
    question: '¿Cómo funciona?',
    answer:
      'Entrás al Prode Mundial 2026 con tu cartón, cargás tus resultados exactos y tu top 4 antes del cierre, y seguís tu posición en el ranking a medida que se juegan los partidos.',
  },
  {
    question: '¿Necesito saber de crypto para jugar?',
    answer:
      'No hace falta ser experto. La experiencia está pensada para que la parte técnica no te frene. Como diría el Chiqui: "No trates de entenderla, disfrutala".',
  },
  {
    question: '¿Cómo participo?',
    answer:
      'Sumate a la lista de espera y te avisamos cuando abramos el Prode Mundial 2026.',
  },
  {
    question: '¿Cómo se define el ranking?',
    answer:
      'El ranking se ordena por puntaje total. Si dos o más cartones empatan, comparten posición con lógica de competencia estándar: 1, 2, 2, 4.',
  },
  {
    question: '¿Qué puedo ganar?',
    answer:
      'Premios reales según tu posición final. Se cobran en USDC y alcanzan a los primeros 32 puestos con una pirámide fija de porcentajes sobre el pozo premiable.',
  },
  {
    question: '¿Cuándo se lanza?',
    answer:
      'Antes del silbatazo inicial del Mundial 2026. La fecha exacta la anunciamos por la lista de espera.',
  },
  {
    question: '¿Qué significa que sea onchain?',
    answer:
      'Que las reglas, los puntajes y los premios quedan verificables públicamente. No dependés de que alguien te diga que fue justo: podés comprobarlo y cobrar tu premio sin intermediarios.',
  },
]

const socialLinks = []
const activeSocialLinks = socialLinks.filter((link) => link.href)

const faqStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
}

const year = new Date().getFullYear()
---

<BaseLayout title={page.title} description={page.description} structuredData={faqStructuredData}>
  <a class="skip-link" href="#contenido">Saltar al contenido</a>

  <header class="site-header">
    <div class="shell header-inner">
      <a class="brand" href="#top" aria-label="ProDefi, inicio">
        <span class="brand-wordmark">PRODEFI</span>
        <span class="brand-ball" aria-hidden="true">⚽</span>
      </a>

      <nav class="header-nav" aria-label="Navegación principal">
        <a href="#countdown">Mundial</a>
        <a href="#premios">Premios</a>
        <a href="#waitlist">Lista de espera</a>
        <a href="#faq">FAQ</a>
      </nav>

      <a class="chip-link chip-link--accent" href="#waitlist">Sumarme</a>
    </div>
    <div class="afa-stripe afa-stripe--thin" aria-hidden="true"></div>
  </header>

  <main id="contenido">
    <section class="hero" id="top">
      <div class="hero-glow" aria-hidden="true"></div>
      <div class="shell hero-grid">
        <div class="hero-copy">
          <div class="kicker-row">
            <span class="kicker-line"></span>
            <p class="eyebrow eyebrow--celeste">Prode Mundial 2026 · Predicciones onchain</p>
          </div>

          <h1 class="display hero-title">
            Prode Mundial<br />
            <span class="editorial">2026</span>
          </h1>

          <p class="hero-lead">
            Jugá el <strong>Prode Mundial 2026</strong>: conseguí tu cartón, cargá predicciones de resultados y del top 4, y competí por <strong>premios reales</strong> en un ranking verificable.
          </p>

          <div class="cta-row">
            <a class="button button--accent" href="#waitlist">Sumate a la lista de espera</a>
            <!-- TODO: recuperar CTA a la app cuando exista una version publica. -->
          </div>

          <p class="trust-row">
            <span class="trust-dot"></span>
            <span>Prode mundial · Reglas públicas · Ranking verificable</span>
          </p>
        </div>

        <div class="hero-visual">
          <div class="hero-card">
            <img
              class="hero-card__poster"
              src={worldCupPoster.src}
              alt="Poster oficial del Mundial 2026"
              loading="eager"
              decoding="async"
            />
            <div class="hero-card__grain"></div>
          </div>
        </div>
      </div>

      <div class="afa-stripe" aria-hidden="true"></div>

      <div class="hero-steps-wrap">
        <div class="shell hero-steps">
          {steps.map((step, index) => (
            <article class:list={["step-card", index > 0 && 'step-card--bordered']}>
              <p class="step-number">Paso {step.number}</p>
              <h2 class="display step-title">{step.title}</h2>
              <p class="step-description">{step.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="countdown-section" id="countdown" data-target-date={page.targetDate}>
      <div class="countdown-watermark" aria-hidden="true">2026</div>
      <div class="shell section-inner">
        <div class="section-topline">
          <div class="kicker-row">
            <span class="kicker-line"></span>
            <p class="eyebrow eyebrow--celeste">Cuenta regresiva</p>
          </div>
          <p class="microcopy countdown-microcopy">{page.targetDateLabel} · {page.targetTimeLabel}</p>
        </div>

        <h2 class="display section-title section-title--countdown">
          Falta poco para <span class="editorial">la fiesta</span>
        </h2>
        <p class="section-lead section-lead--countdown">
          El silbatazo inicial del Mundial 2026 está cada vez más cerca. Asegurá tu lugar en
          ProDefi antes de que arranque la pelota.
        </p>

        <div class="countdown-grid" aria-label="Cuenta regresiva al Mundial 2026">
          <div class="countdown-cell">
            <span class="display countdown-value" data-countdown="days">00</span>
            <span class="eyebrow">Días</span>
          </div>
          <div class="countdown-cell">
            <span class="display countdown-value" data-countdown="hours">00</span>
            <span class="eyebrow">Horas</span>
          </div>
          <div class="countdown-cell">
            <span class="display countdown-value" data-countdown="minutes">00</span>
            <span class="eyebrow">Minutos</span>
          </div>
          <div class="countdown-cell">
            <span class="display countdown-value" data-countdown="seconds">00</span>
            <span class="eyebrow">Segundos</span>
          </div>
        </div>

        <div class="meta-strip">
          <span>● En vivo</span>
          <span>La ansiedad también juega</span>
        </div>
      </div>
    </section>

    <section class="prizes-section" id="premios">
      <div class="afa-stripe afa-stripe--thin" aria-hidden="true"></div>
      <div class="shell section-inner section-inner--light">
        <div class="kicker-row kicker-row--ink">
          <span class="kicker-line kicker-line--ink"></span>
          <p class="eyebrow eyebrow--ink">Premios</p>
        </div>

        <div class="prizes-headline">
          <h2 class="display section-title section-title--ink">
            Más acertás<br /><span class="editorial">más te llevás</span>
          </h2>
          <p class="section-lead section-lead--ink">
            El pozo crece hasta que se cierran las inscripciones. Treinta y dos cobran. El resto
            mira desde abajo. ¿Te alcanza para entrar?
          </p>
        </div>

        <div class="prize-grid">
          {prizeCards.map((card, index) => (
            <article
              class:list={[
                'prize-card',
                index === 0 && 'prize-card--dark',
                index === 1 && 'prize-card--celeste',
                index === 2 && 'prize-card--light',
              ]}
            >
              <p class:list={[
                'eyebrow',
                index === 0 ? 'eyebrow--lima' : 'eyebrow--ink',
              ]}>
                {card.eyebrow}
              </p>
              <h3 class="display prize-heading">{card.title}</h3>
              <p class:list={['prize-body', index === 2 && 'prize-body--muted']}>{card.description}</p>
              <p class="prize-note">{card.note}</p>
              {card.href && card.cta && (
                <a class="button button--outline" href={card.href}>{card.cta}</a>
              )}
            </article>
          ))}
        </div>

        <div class="light-meta-strip">
          <span>● Pozo único </span>
          <span>● 32 premiados</span>
          <span>● Reglas públicas</span>
        </div>
      </div>
      <div class="afa-stripe afa-stripe--thin" aria-hidden="true"></div>
    </section>

    <section class="waitlist-section" id="waitlist" data-waitlist-action={page.waitlistAction}>
      <div class="waitlist-lines" aria-hidden="true"></div>
      <div class="shell waitlist-inner">
        <div class="waitlist-kicker">
          <span class="kicker-line kicker-line--accent"></span>
          <p class="eyebrow eyebrow--lima">Lista de espera</p>
          <span class="kicker-line kicker-line--accent"></span>
        </div>

        <h2 class="display section-title section-title--center">
          Que no te lo<br /><span class="editorial">cuente otro</span>
        </h2>

        <p class="section-lead section-lead--center">
          Dejanos tu mail y te avisamos apenas abramos los cartones. Prioridad de acceso, cero spam,
          cero vueltas.
        </p>

        <form class="waitlist-form" method="post" action={page.waitlistAction} data-waitlist-form novalidate>
          <label class="sr-only" for="waitlist-email">Email</label>
          <input
            id="waitlist-email"
            name="email"
            type="email"
            placeholder="tu@email.com"
            autocomplete="email"
            required
          />
          <button class="button button--accent" type="submit">Sumarme</button>
        </form>

        <p class="waitlist-feedback" data-waitlist-feedback aria-live="polite">
          {page.launchMessage}
        </p>
      </div>
    </section>
    <div class="afa-stripe afa-stripe--thin" aria-hidden="true"></div>
    <section class="faq-section" id="faq">
      <div class="shell section-inner">
        <div class="kicker-row">
          <span class="kicker-line"></span>
          <p class="eyebrow eyebrow--celeste">Preguntas frecuentes</p>
        </div>

        <h2 class="display section-title">
          ¿Tenés <span class="editorial">dudas</span>? Las sacamos
        </h2>

        <div class="faq-list">
          {faqItems.map((item, index) => (
            <details class="faq-item" open={index === 0}>
              <summary>
                <span class="faq-title-wrap">
                  <span class="mono faq-index">{String(index + 1).padStart(2, '0')}</span>
                  <span class="display faq-question">{item.question}</span>
                </span>
                <span class="faq-plus" aria-hidden="true">+</span>
              </summary>
              <div class="faq-answer">
                <p>{item.answer}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="afa-stripe afa-stripe--thin" aria-hidden="true"></div>
    <div class="shell footer-inner">
      <div class="footer-brand" aria-label="ProDefi">
        <p class="display footer-wordmark">PRODEFI</p>
        <span class="footer-brand-ball" aria-hidden="true">⚽</span>
      </div>

      <div class="footer-grid">
        <div>
          <p class="eyebrow">Navegación</p>
          <div class="footer-links">
            <a href="#waitlist">Lista de espera</a>
            <a href="#faq">FAQ</a>
            <a href="/reglas">Reglas</a>
            <!-- TODO: agregar link a la app cuando exista una version publica. -->
          </div>
        </div>

        <div>
          <p class="eyebrow">Comunidad</p>
          <div class="footer-links">
            {activeSocialLinks.length > 0 ? (
              activeSocialLinks.map((link) => <a href={link.href}>{link.label}</a>)
            ) : (
              <p class="footer-note">Canales oficiales en camino.</p>
            )}
          </div>
        </div>

        <div>
          <p class="eyebrow">Estado</p>
          <div class="footer-links">
            <p class="footer-note">Waitlist abierta. Reglas y estructura de premios ya publicadas.</p>
            <p class="footer-note">Hecho en Argentina, con la pelota en los pies.</p>
          </div>
        </div>
      </div>

      <div class="footer-meta">
        <span>© {year} ProDefi · Todos los partidos</span>
        <span>Predicciones · Mundial 2026</span>
      </div>
    </div>
  </footer>

  <script is:inline>
    const countdownRoot = document.querySelector('[data-target-date]')
    if (countdownRoot) {
      const target = new Date(countdownRoot.dataset.targetDate || '').getTime()
      const nodes = {
        days: countdownRoot.querySelector('[data-countdown="days"]'),
        hours: countdownRoot.querySelector('[data-countdown="hours"]'),
        minutes: countdownRoot.querySelector('[data-countdown="minutes"]'),
        seconds: countdownRoot.querySelector('[data-countdown="seconds"]'),
      }

      const paintCountdown = () => {
        const diff = Math.max(0, target - Date.now())
        const days = Math.floor(diff / 86400000)
        const hours = Math.floor((diff % 86400000) / 3600000)
        const minutes = Math.floor((diff % 3600000) / 60000)
        const seconds = Math.floor((diff % 60000) / 1000)

        const values = { days, hours, minutes, seconds }
        for (const [key, value] of Object.entries(values)) {
          if (nodes[key]) nodes[key].textContent = String(value).padStart(2, '0')
        }
      }

      paintCountdown()
      window.setInterval(paintCountdown, 1000)
    }

    const waitlistSection = document.querySelector('[data-waitlist-action]')
    const waitlistForm = document.querySelector('[data-waitlist-form]')
    const waitlistFeedback = document.querySelector('[data-waitlist-feedback]')
    if (waitlistSection && waitlistForm && waitlistFeedback) {
      const endpoint = waitlistSection.dataset.waitlistAction || ''
      const emailInput = waitlistForm.querySelector('input[type="email"]')

      waitlistForm.addEventListener('submit', async (event) => {
        if (!(emailInput instanceof HTMLInputElement)) return

        const email = emailInput.value.trim()
        const isValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)
        if (!isValid) {
          event.preventDefault()
          waitlistFeedback.textContent = 'Mirá, ese mail no anda. Probá de nuevo.'
          waitlistFeedback.dataset.state = 'error'
          return
        }

        if (!endpoint) {
          event.preventDefault()
          waitlistFeedback.textContent =
            'La lista de espera abre pronto. Volvé en un rato para dejar tu mail.'
          waitlistFeedback.dataset.state = 'idle'
          return
        }

        event.preventDefault()
        waitlistFeedback.textContent = 'Enviando...'
        waitlistFeedback.dataset.state = 'idle'

        try {
          const response = await fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          })

          if (!response.ok) throw new Error('bad response')

          waitlistForm.reset()
          waitlistFeedback.textContent = 'Estás adentro. Te avisamos apenas abramos los cartones.'
          waitlistFeedback.dataset.state = 'success'
        } catch {
          waitlistFeedback.textContent = 'No pudimos guardar tu mail. Probá de nuevo en un rato.'
          waitlistFeedback.dataset.state = 'error'
        }
      })
    }
  </script>
</BaseLayout>
