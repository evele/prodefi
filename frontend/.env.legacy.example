# Legacy local flow: Anvil + wallet EOA + RainbowKit fallback.
# Openfort stays disabled while the keys remain empty.

VITE_CHAIN_ID=31337
VITE_CHAIN_NAME=Anvil
VITE_RPC_URL=http://127.0.0.1:8545
VITE_CHAIN_CURRENCY_NAME=Ether
VITE_CHAIN_CURRENCY_SYMBOL=ETH
VITE_CHAIN_CURRENCY_DECIMALS=18

VITE_CARTON_ADDRESS=0x0000000000000000000000000000000000000000
VITE_PREDICTIONS_ADDRESS=0x0000000000000000000000000000000000000000
VITE_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
VITE_USDC_ADDRESS=0x0000000000000000000000000000000000000000

VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
VITE_FIREBASE_FUNCTIONS_BASE_URL=https://southamerica-east1-your-project.cloudfunctions.net
# Prefer initPoint by default. For test purchases, use test credentials + buyer test user
# in an incognito window. Only enable sandbox explicitly if you really need that URL.
VITE_MERCADO_PAGO_USE_SANDBOX=false
VITE_OPENFORT_PUBLISHABLE_KEY=
VITE_OPENFORT_SHIELD_PUBLISHABLE_KEY=
